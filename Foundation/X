<div>
  <input type="radio" id="tab1" name="tabs" checked>
  <label for="tab1">Tab 1</label>
  <input type="radio" id="tab2" name="tabs">
  <label for="tab2">Tab 2</label>
  
  <div id="content1" class="tab-content" style="display:block;">
    Content for tab 1
  </div>
  <div id="content2" class="tab-content" style="display:none;">
    Content for tab 2
  </div>
</div>

<style>
input[type="radio"] { display: none; }
label { cursor: pointer; padding: 10px; border: 1px solid #ccc; }
input[type="radio"]:checked + label { background: #007bff; color: white; }
#tab1:checked ~ #content1,
#tab2:checked ~ #content2 { display: block !important; }
#tab1:checked ~ #content2,
#tab2:checked ~ #content1 { display: none !important; }
</style>
